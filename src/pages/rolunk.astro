---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, COMPANY_NAME } from '../consts';
---

<!doctype html>
<html lang="hu">
	<head>
		<BaseHead title={`Rólunk | ${SITE_TITLE}`} description="Ismerje meg az Outline CE Hungary csapatát és történetünket. Több évtizedes tapasztalat a professzionális hangtechnika terén." />
	</head>
	<body>
		<Header />
		<main>
			<!-- Page Hero -->
			<section class="page-hero">
				<div class="page-hero-bg"><div class="page-hero-grid"></div></div>
				<div class="container">
					<div class="page-hero-content">
						<span class="section-label reveal">Rólunk</span>
						<h1 class="reveal">Ismerjük meg egymást</h1>
						<p class="reveal">Az {COMPANY_NAME} csapata szenvedélyesen elkötelezett a tökéletes hangzás iránt.</p>
					</div>
				</div>
			</section>

			<!-- Story -->
			<section class="story-section">
				<div class="container">
					<div class="story-grid">
						<div class="story-left reveal">
							<span class="section-label">Történetünk</span>
							<h2>Több évtizede a szakma élvonalában</h2>
						</div>
						<div class="story-right reveal">
							<p>
								Az {COMPANY_NAME} a professzionális hangtechnika terén több évtizedes tapasztalattal rendelkező vállalat.
								Cégünk a közép-európai régió egyik meghatározó szereplője a hangosítási technológia területén.
							</p>
							<p>
								Alapításunk óta célunk, hogy ügyfeleinknek a legmagasabb minőségű audió megoldásokat nyújtsuk.
								A világ vezető hangosítási technológiáit képviseljük Magyarországon, és széleskörű műszaki
								tudásunkat állítjuk partnereink szolgálatába.
							</p>
						</div>
					</div>
				</div>
			</section>

			<!-- Values -->
			<section class="values-section">
				<div class="container">
					<div class="section-header reveal">
						<span class="section-label">Amit képviselünk</span>
						<h2 class="section-title">Értékeink</h2>
					</div>
					<div class="values-grid">
						<div class="value-card reveal">
							<div class="value-card-top">
								<span class="value-num">01</span>
							</div>
							<h3>Minőség</h3>
							<p>Csak a legjobb minőségű termékeket és szolgáltatásokat kínáljuk. Minden projektben a tökéletességre törekszünk.</p>
						</div>
						<div class="value-card reveal">
							<div class="value-card-top">
								<span class="value-num">02</span>
							</div>
							<h3>Megbízhatóság</h3>
							<p>Partnereink számíthatnak ránk. Pontos szállítás, precíz kivitelezés és folyamatos műszaki támogatás jellemez minket.</p>
						</div>
						<div class="value-card reveal">
							<div class="value-card-top">
								<span class="value-num">03</span>
							</div>
							<h3>Innováció</h3>
							<p>Folyamatosan követjük a legújabb technológiai fejlesztéseket, hogy ügyfeleinknek a legmodernebb megoldásokat ajánlhassuk.</p>
						</div>
						<div class="value-card reveal">
							<div class="value-card-top">
								<span class="value-num">04</span>
							</div>
							<h3>Szakértelem</h3>
							<p>Csapatunk tapasztalt mérnökökből és technikusokból áll, akik szenvedélyesen rajonganak a tökéletes hangzásért.</p>
						</div>
					</div>
				</div>
			</section>

			<!-- Why Us -->
			<section class="why-section">
				<div class="container">
					<div class="section-header reveal">
						<span class="section-label">Miért mi?</span>
						<h2 class="section-title">Miért válasszon minket?</h2>
					</div>
					<div class="why-grid">
						<div class="why-item reveal">
							<div class="why-item-num">01</div>
							<div class="why-item-body">
								<h4>Széleskörű termékportfólió</h4>
								<p>A világ vezető hangosítási technológiáinak képviselete és forgalmazása Közép-Európában.</p>
							</div>
						</div>
						<div class="why-item reveal">
							<div class="why-item-num">02</div>
							<div class="why-item-body">
								<h4>Teljes körű megoldások</h4>
								<p>A tervezéstől a telepítésig és a szervizig minden szolgáltatást egy kézből biztosítunk.</p>
							</div>
						</div>
						<div class="why-item reveal">
							<div class="why-item-num">03</div>
							<div class="why-item-body">
								<h4>Tapasztalt csapat</h4>
								<p>Mérnökeink és technikusaink több évtizedes szakmai tapasztalattal rendelkeznek.</p>
							</div>
						</div>
						<div class="why-item reveal">
							<div class="why-item-num">04</div>
							<div class="why-item-body">
								<h4>Gyors reagálás</h4>
								<p>24/7 műszaki támogatás és gyors szerviz a rendszerek megbízható működéséhez.</p>
							</div>
						</div>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	/* Page hero */
	.page-hero {
		position: relative;
		padding: calc(var(--nav-height) + 5rem) 0 5rem;
		background: var(--bg-primary);
		overflow: hidden;
	}
	.page-hero-bg { position: absolute; inset: 0; pointer-events: none; }
	.page-hero-grid {
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(var(--border) 1px, transparent 1px),
			linear-gradient(90deg, var(--border) 1px, transparent 1px);
		background-size: 60px 60px;
		mask-image: radial-gradient(ellipse 100% 100% at 50% 0%, black 20%, transparent 80%);
	}
	.page-hero-content {
		position: relative;
		z-index: 1;
		max-width: 700px;
	}
	.page-hero-content h1 { margin: 0.5rem 0 1rem; }
	.page-hero-content p {
		color: var(--text-secondary);
		font-size: 1.1rem;
		line-height: 1.7;
		margin: 0;
	}

	/* Story */
	.story-section {
		padding: var(--section-padding);
		background: var(--bg-secondary);
		border-bottom: 1px solid var(--border);
	}
	.story-grid {
		display: grid;
		grid-template-columns: 1fr 1.4fr;
		gap: 5rem;
		align-items: start;
	}
	.story-left h2 {
		font-size: clamp(1.6rem, 3vw, 2.4rem);
		margin: 0.5rem 0 0;
	}
	.story-right p {
		color: var(--text-secondary);
		line-height: 1.8;
		font-size: 0.95rem;
	}

	/* Values */
	.values-section {
		padding: var(--section-padding);
		background: var(--bg-primary);
	}
	.section-header { margin-bottom: 3.5rem; }
	.section-header .section-title { text-align: left; margin-bottom: 0; }

	.values-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1.5rem;
	}
	.value-card {
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 6px;
		padding: 2rem 1.5rem;
		transition: border-color 0.3s, transform 0.3s;
	}
	.value-card:hover {
		border-color: var(--border-hover);
		transform: translateY(-3px);
	}
	.value-card-top { margin-bottom: 1.25rem; }
	.value-num {
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.1em;
		color: var(--accent);
	}
	.value-card h3 {
		font-size: 1.05rem;
		margin-bottom: 0.75rem;
	}
	.value-card p {
		font-size: 0.85rem;
		color: var(--text-secondary);
		line-height: 1.65;
		margin: 0;
	}

	/* Why us */
	.why-section {
		padding: var(--section-padding);
		background: var(--bg-secondary);
	}
	.why-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
	}
	.why-item {
		display: flex;
		gap: 1.5rem;
		align-items: flex-start;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 6px;
		padding: 2rem;
		transition: border-color 0.3s;
	}
	.why-item:hover { border-color: var(--border-hover); }
	.why-item-num {
		font-size: 1.8rem;
		font-weight: 800;
		color: var(--accent);
		line-height: 1;
		flex-shrink: 0;
		opacity: 0.7;
	}
	.why-item-body h4 {
		margin-bottom: 0.5rem;
		font-size: 1rem;
	}
	.why-item-body p {
		color: var(--text-secondary);
		font-size: 0.85rem;
		line-height: 1.65;
		margin: 0;
	}

	@media (max-width: 1024px) {
		.values-grid { grid-template-columns: repeat(2, 1fr); }
	}
	@media (max-width: 768px) {
		.story-grid { grid-template-columns: 1fr; gap: 2rem; }
		.values-grid { grid-template-columns: 1fr; }
		.why-grid { grid-template-columns: 1fr; }
		.section-header .section-title { text-align: center; }
		.section-header { text-align: center; }
	}
</style>

<script>
	const revealEls = document.querySelectorAll('.reveal');
	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add('visible');
					observer.unobserve(entry.target);
				}
			});
		},
		{ threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
	);
	revealEls.forEach((el) => observer.observe(el));
</script>
