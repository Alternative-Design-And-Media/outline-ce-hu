---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION, COMPANY_EMAIL, COMPANY_PHONE } from '../consts';
---

<!doctype html>
<html lang="hu">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero Section -->
			<section class="hero">
				<div class="hero-content">
					<h1>Professzionális Hangtechnikai Megoldások</h1>
					<p>
						Az Outline CE Hungary a professzionális audió technológia vezető képviselője Közép-Európában.
						Hangosítás, rendszertervezés és műszaki támogatás a legmagasabb színvonalon.
					</p>
					<div class="hero-buttons">
						<a href="/szolgaltatasok" class="btn btn-primary">Szolgáltatásaink</a>
						<a href="/kapcsolat" class="btn btn-outline">Kapcsolat</a>
					</div>
				</div>
			</section>

			<!-- Services Preview -->
			<section class="services-preview">
				<div class="container">
					<h2 class="section-title">Szolgáltatásaink</h2>
					<p class="section-subtitle">
						Teljes körű hangtechnikai megoldásokat kínálunk a tervezéstől a kivitelezésig.
					</p>
					<div class="services-grid">
						<div class="service-card">
							<div class="service-icon">🔊</div>
							<h3>Hangosítás</h3>
							<p>
								Professzionális hangosító rendszerek tervezése és telepítése koncerttermek,
								konferenciatermek és rendezvényhelyszínek számára.
							</p>
						</div>
						<div class="service-card">
							<div class="service-icon">🎛️</div>
							<h3>Rendszertervezés</h3>
							<p>
								Egyedi audió rendszerek megtervezése az Ön igényeinek megfelelően,
								a legmodernebb technológia felhasználásával.
							</p>
						</div>
						<div class="service-card">
							<div class="service-icon">🎵</div>
							<h3>Rendezvénytechnika</h3>
							<p>
								Rendezvények hangtechnikai kiszolgálása a legkisebb konferenciától
								a legnagyobb fesztiválokig.
							</p>
						</div>
						<div class="service-card">
							<div class="service-icon">🛠️</div>
							<h3>Szerviz és Támogatás</h3>
							<p>
								Szerviz, karbantartás és műszaki tanácsadás a rendszerek
								hosszú távú megbízható működéséhez.
							</p>
						</div>
					</div>
					<div class="text-center" style="margin-top: 2rem;">
						<a href="/szolgaltatasok" class="btn btn-primary">Összes szolgáltatás</a>
					</div>
				</div>
			</section>

			<!-- About Preview -->
			<section class="about-preview">
				<div class="container">
					<div class="about-grid">
						<div class="about-text">
							<h2>Rólunk</h2>
							<p>
								Az Outline CE Hungary a professzionális hangtechnika terén szerzett több évtizedes tapasztalattal
								rendelkezik. Vállalatunk a közép-európai régió vezető audió megoldásszállítója, amely
								a legmagasabb minőségű termékeket és szolgáltatásokat kínálja ügyfeleinek.
							</p>
							<p>
								Csapatunk tapasztalt mérnökökből és technikusokból áll, akik elkötelezettek a tökéletes
								hangzás iránt. Legyen szó színházi előadásról, nagyszabású fesztiválról vagy céges
								rendezvényről, mi biztosítjuk a professzionális hangminőséget.
							</p>
							<a href="/rolunk" class="btn btn-primary">Tudjon meg többet</a>
						</div>
						<div class="about-stats">
							<div class="stat">
								<span class="stat-number">20+</span>
								<span class="stat-label">Év tapasztalat</span>
							</div>
							<div class="stat">
								<span class="stat-number">500+</span>
								<span class="stat-label">Sikeres projekt</span>
							</div>
							<div class="stat">
								<span class="stat-number">100+</span>
								<span class="stat-label">Elégedett ügyfél</span>
							</div>
							<div class="stat">
								<span class="stat-number">24/7</span>
								<span class="stat-label">Műszaki támogatás</span>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- CTA Section -->
			<section class="cta-section">
				<div class="container text-center">
					<h2>Készen áll a következő projektre?</h2>
					<p>
						Vegye fel velünk a kapcsolatot, és segítünk megtalálni a tökéletes hangtechnikai megoldást az Ön igényeinek megfelelően.
					</p>
					<div class="cta-buttons">
						<a href="/kapcsolat" class="btn btn-primary">Ajánlatkérés</a>
						<a href={`tel:${COMPANY_PHONE.replace(/\s/g, '')}`} class="btn btn-outline-dark">
							📞 {COMPANY_PHONE}
						</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	/* Hero */
	.hero {
		background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
		color: var(--white);
		padding: 6rem 1.5em;
		text-align: center;
		min-height: 500px;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.hero-content {
		max-width: 800px;
		margin: 0 auto;
	}
	.hero h1 {
		font-size: 3em;
		color: var(--white);
		margin-bottom: 1rem;
		line-height: 1.15;
	}
	.hero p {
		font-size: 1.15em;
		color: rgba(255, 255, 255, 0.85);
		margin-bottom: 2rem;
		line-height: 1.7;
	}
	.hero-buttons {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	/* Services Preview */
	.services-preview {
		padding: var(--section-padding);
		background: #f8f9fa;
	}
	.services-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 2rem;
	}
	.service-card {
		background: var(--white);
		padding: 2em;
		border-radius: 8px;
		box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
		text-align: center;
		transition: transform 0.3s, box-shadow 0.3s;
	}
	.service-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
	}
	.service-icon {
		font-size: 2.5em;
		margin-bottom: 0.8em;
	}
	.service-card h3 {
		color: var(--primary);
		margin-bottom: 0.8em;
		font-size: 1.2em;
	}
	.service-card p {
		color: rgb(var(--gray));
		font-size: 0.9em;
		line-height: 1.6;
	}

	/* About Preview */
	.about-preview {
		padding: var(--section-padding);
	}
	.about-grid {
		display: grid;
		grid-template-columns: 1.5fr 1fr;
		gap: 3rem;
		align-items: center;
	}
	.about-text h2 {
		color: var(--primary);
		margin-bottom: 1rem;
	}
	.about-text p {
		color: rgb(var(--gray-dark));
		line-height: 1.8;
	}
	.about-text .btn {
		margin-top: 1rem;
	}
	.about-stats {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
	}
	.stat {
		background: #f8f9fa;
		padding: 1.5em;
		border-radius: 8px;
		text-align: center;
		border-left: 3px solid var(--accent);
	}
	.stat-number {
		display: block;
		font-size: 2em;
		font-weight: 700;
		color: var(--accent);
	}
	.stat-label {
		display: block;
		font-size: 0.85em;
		color: rgb(var(--gray));
		margin-top: 0.3em;
	}

	/* CTA Section */
	.cta-section {
		background: linear-gradient(135deg, var(--primary-light) 0%, var(--primary) 100%);
		color: var(--white);
		padding: var(--section-padding);
	}
	.cta-section h2 {
		color: var(--white);
		margin-bottom: 1rem;
	}
	.cta-section p {
		color: rgba(255, 255, 255, 0.85);
		max-width: 600px;
		margin: 0 auto 2rem;
		font-size: 1.05em;
	}
	.cta-buttons {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}
	.btn-outline-dark {
		background: transparent;
		color: var(--white);
		border: 2px solid rgba(255, 255, 255, 0.5);
		display: inline-block;
		padding: 0.8em 2em;
		border-radius: 4px;
		font-weight: 700;
		text-decoration: none;
		transition: all 0.3s ease;
	}
	.btn-outline-dark:hover {
		background: rgba(255, 255, 255, 0.1);
		border-color: var(--white);
		color: var(--white);
	}

	@media (max-width: 720px) {
		.hero {
			padding: 4rem 1em;
			min-height: auto;
		}
		.hero h1 {
			font-size: 2em;
		}
		.about-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
