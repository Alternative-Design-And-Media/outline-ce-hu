---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, COMPANY_NAME, COMPANY_EMAIL, COMPANY_PHONE, COMPANY_ADDRESS } from '../consts';
---

<!doctype html>
<html lang="hu">
	<head>
		<BaseHead title={`Kapcsolat | ${SITE_TITLE}`} description="Vegye fel velünk a kapcsolatot! Kérjen ajánlatot professzionális hangtechnikai megoldásainkra." />
	</head>
	<body>
		<Header />
		<main>
			<!-- Page Header -->
			<section class="page-header">
				<div class="container">
					<h1>Kapcsolat</h1>
					<p>Vegye fel velünk a kapcsolatot</p>
				</div>
			</section>

			<!-- Contact Content -->
			<section class="contact-content">
				<div class="container">
					<div class="contact-grid">
						<!-- Contact Info -->
						<div class="contact-info">
							<h2>Elérhetőségeink</h2>
							<p>
								Keressen minket bizalommal! Csapatunk készséggel áll rendelkezésére
								bármilyen hangtechnikai kérdésben.
							</p>

							<div class="contact-detail">
								<div class="contact-detail-icon">📧</div>
								<div>
									<h4>E-mail</h4>
									<a href={`mailto:${COMPANY_EMAIL}`}>{COMPANY_EMAIL}</a>
								</div>
							</div>

							<div class="contact-detail">
								<div class="contact-detail-icon">📞</div>
								<div>
									<h4>Telefon</h4>
									<a href={`tel:${COMPANY_PHONE.replace(/\s/g, '')}`}>{COMPANY_PHONE}</a>
								</div>
							</div>

							<div class="contact-detail">
								<div class="contact-detail-icon">📍</div>
								<div>
									<h4>Cím</h4>
									<p>{COMPANY_ADDRESS}</p>
								</div>
							</div>

							<div class="contact-detail">
								<div class="contact-detail-icon">🕐</div>
								<div>
									<h4>Nyitvatartás</h4>
									<p>Hétfő – Péntek: 9:00 – 17:00</p>
								</div>
							</div>
						</div>

						<!-- Contact Form -->
						<div class="contact-form-container">
							<h2>Üzenet küldése</h2>
							<form class="contact-form" id="contact-form">
								<div class="form-group">
									<label for="name">Név *</label>
									<input type="text" id="name" name="name" required placeholder="Az Ön neve" />
								</div>
								<div class="form-group">
									<label for="email">E-mail *</label>
									<input type="email" id="email" name="email" required placeholder="Az Ön e-mail címe" />
								</div>
								<div class="form-group">
									<label for="phone">Telefon</label>
									<input type="tel" id="phone" name="phone" placeholder="Az Ön telefonszáma" />
								</div>
								<div class="form-group">
									<label for="subject">Tárgy *</label>
									<input type="text" id="subject" name="subject" required placeholder="Üzenet tárgya" />
								</div>
								<div class="form-group full-width">
									<label for="message">Üzenet *</label>
									<textarea id="message" name="message" rows="5" required placeholder="Írja le kérését..."></textarea>
								</div>
								<div class="form-group full-width">
									<button type="submit" class="btn btn-primary">Üzenet küldése</button>
								</div>
							</form>
						</div>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-header {
		background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
		color: var(--white);
		padding: 4rem 1.5em;
		text-align: center;
	}
	.page-header h1 {
		color: var(--white);
		margin-bottom: 0.5rem;
	}
	.page-header p {
		color: rgba(255, 255, 255, 0.8);
		font-size: 1.15em;
	}

	.contact-content {
		padding: var(--section-padding);
	}
	.contact-grid {
		display: grid;
		grid-template-columns: 1fr 1.2fr;
		gap: 4rem;
	}
	.contact-info h2,
	.contact-form-container h2 {
		color: var(--primary);
		margin-bottom: 1rem;
	}
	.contact-info > p {
		color: rgb(var(--gray));
		margin-bottom: 2rem;
		line-height: 1.7;
	}
	.contact-detail {
		display: flex;
		gap: 1rem;
		align-items: flex-start;
		margin-bottom: 1.5rem;
	}
	.contact-detail-icon {
		font-size: 1.5em;
		flex-shrink: 0;
		width: 40px;
		text-align: center;
	}
	.contact-detail h4 {
		color: var(--primary);
		margin-bottom: 0.2em;
		font-size: 1em;
	}
	.contact-detail p,
	.contact-detail a {
		color: rgb(var(--gray-dark));
		font-size: 0.95em;
		margin: 0;
	}
	.contact-detail a:hover {
		color: var(--accent);
	}

	/* Form */
	.contact-form {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.2rem;
	}
	.form-group {
		display: flex;
		flex-direction: column;
	}
	.form-group.full-width {
		grid-column: 1 / -1;
	}
	.form-group label {
		font-size: 0.9em;
		font-weight: 700;
		color: rgb(var(--gray-dark));
		margin-bottom: 0.4em;
	}
	.form-group input,
	.form-group textarea {
		padding: 0.75em 1em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 4px;
		font-family: inherit;
		font-size: 0.95em;
		transition: border-color 0.3s;
		background: var(--white);
	}
	.form-group input:focus,
	.form-group textarea:focus {
		outline: none;
		border-color: var(--accent);
		box-shadow: 0 0 0 3px rgba(233, 69, 96, 0.1);
	}
	.form-group textarea {
		resize: vertical;
		min-height: 120px;
	}

	@media (max-width: 720px) {
		.contact-grid {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
		.contact-form {
			grid-template-columns: 1fr;
		}
	}
</style>
