---
import { COMPANY_NAME, COMPANY_EMAIL, COMPANY_PHONE, COMPANY_ADDRESS } from '../consts';
const today = new Date();
---

<footer>
	<div class="footer-content">
		<div class="footer-section">
			<h3>{COMPANY_NAME}</h3>
			<p>Professzionális hangtechnikai megoldások Magyarországon és a közép-európai régióban.</p>
		</div>
		<div class="footer-section">
			<h4>Gyors linkek</h4>
			<ul>
				<li><a href="/">Főoldal</a></li>
				<li><a href="/szolgaltatasok">Szolgáltatások</a></li>
				<li><a href="/rolunk">Rólunk</a></li>
				<li><a href="/kapcsolat">Kapcsolat</a></li>
			</ul>
		</div>
		<div class="footer-section">
			<h4>Kapcsolat</h4>
			<ul>
				<li>📧 <a href={`mailto:${COMPANY_EMAIL}`}>{COMPANY_EMAIL}</a></li>
				<li>📞 <a href={`tel:${COMPANY_PHONE.replace(/\s/g, '')}`}>{COMPANY_PHONE}</a></li>
				<li>📍 {COMPANY_ADDRESS}</li>
			</ul>
		</div>
	</div>
	<div class="footer-bottom">
		<p>&copy; {today.getFullYear()} {COMPANY_NAME}. Minden jog fenntartva.</p>
	</div>
</footer>
<style>
	footer {
		background: var(--primary);
		color: rgba(255, 255, 255, 0.8);
		padding: 3em 1.5em 1em;
	}
	.footer-content {
		max-width: var(--container-width);
		margin: 0 auto;
		display: grid;
		grid-template-columns: 2fr 1fr 1fr;
		gap: 2em;
	}
	.footer-section h3 {
		color: var(--white);
		font-size: 1.3em;
		margin-bottom: 0.8em;
	}
	.footer-section h4 {
		color: var(--white);
		font-size: 1.1em;
		margin-bottom: 0.8em;
	}
	.footer-section p {
		font-size: 0.9em;
		line-height: 1.6;
	}
	.footer-section ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.footer-section ul li {
		margin-bottom: 0.5em;
		font-size: 0.9em;
	}
	.footer-section a {
		color: rgba(255, 255, 255, 0.8);
		text-decoration: none;
		transition: color 0.3s;
	}
	.footer-section a:hover {
		color: var(--accent);
	}
	.footer-bottom {
		max-width: var(--container-width);
		margin: 2em auto 0;
		padding-top: 1.5em;
		border-top: 1px solid rgba(255, 255, 255, 0.15);
		text-align: center;
		font-size: 0.85em;
	}
	@media (max-width: 720px) {
		.footer-content {
			grid-template-columns: 1fr;
			gap: 1.5em;
		}
	}
</style>
